{
  "name": "assbar",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:web": "ng serve",
    "start:web:ready": "wait-on tcp:127.0.0.1:10000 tcp:127.0.0.1:7071 && ng serve",
    "start:azurite": "azurite --location ./.azurite --silent --debug ./.azurite/debug.log",
    "start:functions": "func start --script-root api",
    "start:local": "concurrently -k -n AZURITE,FUNCTIONS,WEB -c magenta,yellow,cyan \"npm run start:azurite\" \"npm run start:functions\" \"npm run start:web:ready\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@fullcalendar/angular": "^6.1.20",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "marked": "^17.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "azurite": "^3.35.0",
    "concurrently": "^9.2.1",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8",
    "wait-on": "^8.0.3"
  },
  "imports": {
    "#tailwind": "./src/styles.css"
  }
}
